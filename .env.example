VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SITE_URL=https://www.agtrenz.com
VITE_OPENCAGE_API_KEY=your-opencage-api-key

# Server-side only (Supabase Edge Function secrets — never put in frontend):
# EXCHANGERATE_API_KEY=your-exchangerate-api-key
# SHIPROCKET_API_EMAIL=your-shiprocket-api-user-email
# SHIPROCKET_API_PASSWORD=your-shiprocket-api-user-password
# SHIPROCKET_WEBHOOK_SECRET=choose-a-long-random-token-for-x-api-key-header
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RAZORPAY_KEY_ID=rzp_live_your_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# SITE_URL=https://www.agtrenz.com

# Auth email (Supabase dashboard — required for OTP emails in production):
# Authentication → SMTP Settings → Enable custom SMTP (Resend)
#   Host: smtp.resend.com | Port: 465 | User: resend | Pass: <RESEND_API_KEY>
#   Sender: noreply@agtrenz.com | Name: AGTRENZ
# Authentication → URL configuration:
#   Site URL: https://www.agtrenz.com
#   Redirect URLs: https://www.agtrenz.com/** , https://agtrenz.com/**
# Authentication → Rate Limits → raise "emails per hour" (default is too low)
# Resend → Domains → verify agtrenz.com (SPF + DKIM DNS records)
